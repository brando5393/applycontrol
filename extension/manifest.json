{
  "manifest_version": 3,
  "name": "ApplyControl",
  "version": "0.1.0",
  "description": "One-click job application capture.",
  "permissions": ["activeTab", "storage", "scripting", "identity"],
  "host_permissions": [
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "action": {
    "default_title": "Save Application",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "dashboard.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
